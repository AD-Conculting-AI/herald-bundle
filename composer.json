{
    "name": "herald-ai/herald-bundle",
    "description": "Symfony bundle for integrating with the Herald multi-agent orchestration engine",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["herald", "ai", "multi-agent", "orchestration", "symfony", "bundle"],
    "homepage": "https://github.com/AD-Conculting-AI/herald-bundle",
    "require": {
        "php": ">=8.2",
        "symfony/config": "^7.0 || ^8.0",
        "symfony/dependency-injection": "^7.0 || ^8.0",
        "symfony/event-dispatcher": "^7.0 || ^8.0",
        "symfony/http-client": "^7.0 || ^8.0",
        "symfony/http-foundation": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/routing": "^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Herald\\Bundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Herald\\Bundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
